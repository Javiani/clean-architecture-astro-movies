---
import Modal from 'shared/components/modal/index.astro'
const { item } = Astro.props
---

<script>
	import { register } from 'shared/main'
	import * as appGallery from './index'
	register('app-gallery', appGallery)
</script>

<app-gallery class="movie-images">
	<div class="container mx-auto px-4 py-16">
		<h2 class="text-4xl font-semibold">Images</h2>
		<div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-8">
		{item.images.map(image => (
			<div class="mt-8">
				<a href={`https://image.tmdb.org/t/p/original/${image.file_path}`} target="_blank" rel="noopener noreferrer">
					<img src={`https://image.tmdb.org/t/p/w500${image.file_path}`} loading="lazy" alt={item.name} class="hover:opacity-75 transition ease-in-out duration-150" />
				</a>
			</div>
		))}
		</div>
		<Modal data-modal-name="gallery">
			<img html-src="image" alt="poster" class="block aspect-video" />
		</Modal>
	</div>
</app-gallery>