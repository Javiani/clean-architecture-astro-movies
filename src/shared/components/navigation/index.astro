---
import Logo from 'shared/components/logo/index.astro'

const { menu } = Astro.props 
const active = 'bg-orange-500'
const selected = ( page: string ) => page === menu? active : ''
---

<script>
    import { register } from 'shared/main'
    import * as appNavigation from './index'
    register('app-navigation', appNavigation) 
</script>

<app-navigation>
    <nav class="nav border-b border-gray-800 sticky top-0 z-30 bg-gray-900">
        <div class="container mx-auto flex flex-col md:flex-row items-center justify-between px-4 py-2">
            <ul class="flex flex-col md:flex-row items-center">
                <li>
                    <a href="/" class="flex items-center font-bold text-xl">
                        <Logo />
                        <span>astro</span>
                        &nbsp;
                        <span class="text-orange-500">movies</span>
                    </a>
                </li>
                <li class="md:ml-16 mt-3 md:mt-0" data-nav-link>
                    <a href="/" class=`hover:text-gray-300 block p-1 px-8 rounded-full ${selected('movies')}`>Movies</a>
                </li>
                <li class="md:ml-6 mt-3 md:mt-0" data-nav-link>
                    <a href="/tv" class=`hover:text-gray-300 block p-1 px-8 rounded-full ${selected('show')}`>TV Shows</a>
                </li> 
            </ul>
        </div>
    </nav>
</app-navigation>

