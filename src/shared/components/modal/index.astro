---
const name = Astro.props['data-modal-name']
---

<script>
    import { register } from 'shared/main'
    import * as appModal from './index'
    register('app-modal', appModal)
</script>

<app-modal 
    data-modal-name={name}
    class="bg-black/50 backdrop-blur fixed inset-0 p-4 shadow-lg overflow-y-auto z-40 hidden" 
    html-class="open? '!flex': 'hidden'"
>
    <div class="m-auto w-full max-w-5xl">
        <div class="bg-gray-900 rounded">
            <div class="flex justify-end pr-4 pt-2">
                <button
                    data-modal-close 
                    class="text-3xl leading-none hover:text-gray-300">&times;
                </button>
            </div>
            <div class="modal-body px-8 py-8">
                <slot />
            </div>
        </div>
    </div>
</app-modal>
