---
import Layout from 'layouts/default.astro'
import Card from 'shared/components/card/index.astro'
import { getTMDBList } from 'shared/services/tmdb'

const { TMDB_API_KEY } = import.meta.env 
const url = 'https://api.themoviedb.org/3/movie/popular?api_key=' + TMDB_API_KEY
const popularMovies = await getTMDBList( url )

---

<Layout title="Astro Movies" menu="movies">
  <div class="container mx-auto px-4 pt-16 mb-16">
    <div class="popular-movies">
      <h2 class="uppercase tracking-wider text-orange-500 text-lg font-semibold">
        Popular Movies
      </h2>
      <div
        class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-8"
      >
        {popularMovies.map((movie) => <Card item={movie} path="/movies" />)}
      </div>
    </div>
  </div>
</Layout>


